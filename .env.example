DATABASE_URL=postgres://pansori:pansori@localhost:5432/pansori_db
FRONTEND_URL=http://localhost:5173

# Docker Compose Postgres config
POSTGRES_USER=pansori
POSTGRES_PASSWORD=pansori
POSTGRES_DB=pansori_db

# Google OAuth (see DEPLOY.md for setup instructions)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Discord OAuth (optional — if both set, "Sign in with Discord" appears on the
# login screen alongside Google). The Discord developer portal hosts the
# redirect URI for /api/auth/discord/callback.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3001/api/auth/discord/callback

# E2E test login bypass — set to 'true' for dev/CI to enable the
# /api/auth/test-login endpoint that Playwright uses. Double-gated against
# NODE_ENV=production. Leave blank or 'false' in production.
E2E_TEST_LOGIN_ENABLED=true

# Session encryption — use a long random string in production
SESSION_SECRET=change-me-to-a-random-secret

# LLM narrative enhancement (set to 'anthropic' to enable; default: 'none')
LLM_PROVIDER=none
ANTHROPIC_API_KEY=
# Optional: override model (default: claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Painted art tier (see ASSETS.md). The public build runs a free glyph/color
# tier. Set VITE_PAINTED_ART=1 if you have the licensed packs under
# src/frontend/public/art/{tiles,markers,icons,sprites} (dev reads this from
# .env). VITE_ASSET_BASE_URL optionally prefixes painted URLs (e.g. a CDN).
VITE_PAINTED_ART=
VITE_ASSET_BASE_URL=
