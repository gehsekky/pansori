{
  // The BUILD project: emits dist/index.js for the production image.
  // The src/tests tree and any stray spec files are excluded — tests
  // never ship compiled into the image.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src"
  },
  "exclude": ["node_modules", "dist", "src/tests", "src/**/*.spec.ts"]
}
