{
  // The WIDE project: source + tests. This is what the typecheck gate
  // (`tsc --noEmit -p src/backend/tsconfig.json`), eslint's type-aware
  // linting (parserOptions.project) and the IDE resolve against. The
  // production build uses tsconfig.build.json (src only, emits dist/).
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
